<Window x:Class="EncryptionSuite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encryption Suite" Height="480" Width="720"
        Background="#f5f5f5"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Encryption Suite"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,20"/>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" Width="400" Margin="0,0,0,20">
            <ComboBox x:Name="CipherSelector" FontSize="16" Width="250" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBox x:Name="InputText" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Text="Enter text here..."
                     GotFocus="InputText_GotFocus" Margin="0,0,0,10"/>
            <TextBox x:Name="KeyBox" Height="30" Text="Enter key (if needed)"
                     GotFocus="KeyBox_GotFocus" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
                <Button x:Name="EncryptBtn" Content="Encrypt" Width="100" Height="40" Margin="5" Click="Encrypt_Click"/>
                <Button x:Name="DecryptBtn" Content="Decrypt" Width="100" Height="40" Margin="5" Click="Decrypt_Click"/>
                <Button x:Name="ClearBtn" Content="Clear" Width="100" Height="40" Margin="5" Click="Clear_Click"/>
            </StackPanel>

            <TextBlock Text="Result:" FontWeight="Bold" Margin="0,10,0,5"/>
            <TextBox x:Name="OutputText" Height="80" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True"/>
        </StackPanel>
    </Grid>
</Window>
